# ─── taste.node Backend Environment ───
# Copy this file to .env and fill in your actual credentials.
# .env should be gitignored and never committed.

# Optional API key guard for mutation endpoints.
# TASTE_NODE_API_KEY=

# CORS origins (comma-separated). Defaults to localhost dev servers.
# TASTE_NODE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase (optional — falls back to SQLite if unset)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
