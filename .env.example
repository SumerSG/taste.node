# taste.node Environment Variables
# Copy this file to .env (backend) and web/.env.local (frontend)
# Both files are gitignored. Never commit real credentials.

# ─── Backend ───

# Optional: protect mutation endpoints with an API key
# TASTE_NODE_API_KEY=

# CORS origins (comma-separated). Defaults to localhost dev servers.
# TASTE_NODE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase (optional — falls back to SQLite if unset)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Frontend (web/.env.local) ───

# Backend URL (optional — enables backend-driven recommendations)
# VITE_API_URL=http://localhost:8000

# Supabase (required for auth + cloud sync)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
