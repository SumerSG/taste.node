# Copy this file to .env.local and fill in your actual credentials
# .env.local is gitignored and should never be committed

# ─── taste.node Backend (FastAPI) ───
# If set, the frontend will route recommendations / clustering / venue queries
# to the FastAPI backend instead of computing everything client-side.
# Example: VITE_API_URL=http://localhost:8000
# VITE_API_URL=

# ─── Client-side (Vite / Supabase) ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Server-side (seed / migration scripts only) ───
# Service Role Key has full database access — keep it secret!
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
