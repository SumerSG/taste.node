# Copy this file to .env.local and fill in your actual credentials
# .env.local is gitignored and should never be committed

# ─── Client-side (Vite) ───
# Get these from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Server-side (seed script only) ───
# Service Role Key has full database access — keep it secret!
# From Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
